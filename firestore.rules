rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Definitions & Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations

    function isValidUser(data) {
      return data.uid == request.auth.uid 
        && data.email is string 
        && data.email.size() <= 128
        && data.username is string 
        && data.username.size() <= 128
        && (!('role' in data) || data.role == 'user');
    }

    function isValidTask(data) {
      return data.taskId is string 
        && data.taskId.size() <= 128
        && data.title is string 
        && data.title.size() > 0 
        && data.title.size() <= 200
        && data.createdBy == request.auth.uid
        && data.status is string
        && data.priority is string;
    }

    function isValidNotification(data) {
      return data.notificationId is string 
        && data.notificationId.size() <= 128
        && data.userId == request.auth.uid
        && data.message is string 
        && data.message.size() <= 500;
    }

    function isValidActivityLog(data) {
      return data.userId == request.auth.uid
        && data.action is string 
        && data.action.size() <= 200;
    }

    // Collections Rules

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['username', 'profileImage', 'bio', 'theme']);
      allow delete: if isOwner(userId);
    }

    match /tasks/{taskId} {
      allow get: if isSignedIn() && existing().createdBy == request.auth.uid;
      allow list: if isSignedIn() && resource.data.createdBy == request.auth.uid;
      
      allow create: if isSignedIn() && isValidId(taskId) && isValidTask(incoming())
        && incoming().taskId == taskId;
        
      allow update: if isSignedIn() && existing().createdBy == request.auth.uid && isValidTask(incoming())
        && incoming().createdBy == existing().createdBy
        && incoming().taskId == existing().taskId
        && incoming().createdAt == existing().createdAt
        && (
          // Action: Normal edits (title, description, status, priority, category, dueDate, attachments, subtasks, isFavorite)
          incoming().diff(existing()).affectedKeys().hasAny(['title', 'description', 'status', 'priority', 'category', 'dueDate', 'attachments', 'subtasks', 'isFavorite', 'completedAt'])
        );
        
      allow delete: if isSignedIn() && existing().createdBy == request.auth.uid;
    }

    match /notifications/{notificationId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(notificationId) && isValidNotification(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid && isValidNotification(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /activityLogs/{logId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(logId) && isValidActivityLog(incoming());
      // Logs are immutable after creation
      allow update, delete: if false;
    }
  }
}
