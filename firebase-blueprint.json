{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string" },
        "profileImage": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Task": {
      "title": "Task",
      "description": "Task details",
      "type": "object",
      "properties": {
        "taskId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "priority": { "type": "string" },
        "status": { "type": "string" },
        "category": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["taskId", "title", "createdBy", "status"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notification",
      "type": "object",
      "properties": {
        "notificationId": { "type": "string" },
        "type": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["notificationId", "type", "message", "timestamp"]
    },
    "ActivityLog": {
      "title": "ActivityLog",
      "description": "User activity log",
      "type": "object",
      "properties": {
        "action": { "type": "string" },
        "userId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["action", "userId", "timestamp"]
    }
  },
  "firestore": {
    "users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "tasks/{taskId}": {
      "schema": "Task",
      "description": "Tasks"
    },
    "notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Notifications"
    },
    "activityLogs/{logId}": {
      "schema": "ActivityLog",
      "description": "Activity logs"
    }
  }
}
